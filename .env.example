# Конфигурация Telegram Posting Bot

# Токен Telegram бота (получить через @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API ключ Groq для генерации постов (получить на console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# ID администратора бота (получить у @userinfobot)
ADMIN_USER_ID=123456789

# PostgreSQL Database URL (опционально, для постоянного хранилища)
# DATABASE_URL=postgresql://user:password@host:5432/database
