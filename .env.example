# Пример конфигурации, скопируйте в .env и заполните ваши ключи

# Токен Telegram бота (получить через @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Meta Threads API через RapidAPI (более простой вариант)
# Получите ключ на: https://rapidapi.com/omgvampire/tools/meta-threads
RAPIDAPI_KEY=YOUR_RAPIDAPI_KEY_HERE
THREADS_USERNAME=YOUR_THREADS_USERNAME_HERE

# Альтернативно: Meta Graph API (нужен Facebook Developer аккаунт)
# META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN_HERE
# META_APP_ID=YOUR_APP_ID_HERE
# THREADS_USER_ID=YOUR_THREADS_USER_ID_HERE

# OpenAI API для генерации контента
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Настройки публикации
POST_FREQUENCY=2  # Количество постов в день (2-3)
TIME_ZONE=Europe/Moscow  # Часовой пояс для расписания
